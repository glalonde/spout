// Spout per-frame GPU pipeline
// Render with: dot -Tsvg assets/pipeline.dot -o assets/pipeline.svg

digraph pipeline {
    rankdir=TB
    node [fontname="Helvetica", fontsize=11]
    edge [fontname="Helvetica", fontsize=9]

    // ─── CPU side ───
    subgraph cluster_cpu {
        label="CPU (update_state)"
        style=filled
        fillcolor="#f0f4ff"
        color="#8888cc"

        input      [label="Input\n(keyboard)", shape=parallelogram]
        ship       [label="ShipState\nupdate", shape=box]
        viewport   [label="viewport_offset\nupdate", shape=box]
        emitter_st [label="Emitter state\n(emit_for_period)", shape=box]
        level_bg   [label="LevelMaker\n(background gen)", shape=box, style=dashed]
    }

    // ─── GPU buffers ───
    subgraph cluster_buffers {
        label="GPU Buffers"
        style=filled
        fillcolor="#fff8e0"
        color="#ccaa00"

        terrain_tiles [label="TerrainTiles\n(loaded_tiles)", shape=cylinder]
        comp_tile     [label="CompositeTile\n(terrain buffer)", shape=cylinder]
        particle_buf  [label="ParticleBuffer\n(ring buffer)", shape=cylinder]
        density_buf   [label="DensityBuffer", shape=cylinder]
        game_tex      [label="GameViewTexture\n(BGRA8 offscreen)", shape=box3d]
        swapchain     [label="SwapChain\n(window surface)", shape=box3d]
    }

    // ─── Compute passes ───
    subgraph cluster_compute {
        label="Compute Passes (GPU)"
        style=filled
        fillcolor="#e8ffe8"
        color="#338833"

        compose    [label="compose_tiles\n(copy_buffer_to_buffer)", shape=box]
        emit_cs    [label="Emitter Compute\n(emitter.wgsl)", shape=box]
        clear_cs   [label="Clear Density\n(clear_density_buffer.wgsl)", shape=box]
        update_cs  [label="Update Particles\n(particles.wgsl)\n[physics + terrain damage]", shape=box]
        decompose  [label="decompose_tiles\n(copy_buffer_to_buffer)", shape=box]
    }

    // ─── Render passes ───
    subgraph cluster_render {
        label="Render Passes (GPU)"
        style=filled
        fillcolor="#ffe8e8"
        color="#883333"

        terrain_rp  [label="Terrain Render Pass\n(terrain.wgsl)", shape=box]
        particle_rp [label="Particle Render Pass\n(render_particles.wgsl)", shape=box]
        ship_rp     [label="Ship Render Pass\n(ship.wgsl)", shape=box]
        blit_rp     [label="Blit Render Pass\n(textured_model.wgsl)\ncamera transform", shape=box]
    }

    // ─── CPU data flow ───
    input      -> ship
    ship       -> viewport
    ship       -> emitter_st

    // ─── Terrain tile management ───
    level_bg   -> terrain_tiles [label="uploads", style=dashed]
    terrain_tiles -> compose    [label="active tiles"]
    compose    -> comp_tile     [label="write"]

    // ─── Compute data flow ───
    emitter_st -> emit_cs       [label="EmitParams\n(uniforms)"]
    emit_cs    -> particle_buf  [label="spawn particles"]
    clear_cs   -> density_buf   [label="zero"]
    comp_tile  -> update_cs     [label="read/write\nterrain"]
    particle_buf -> update_cs   [label="read/write\nparticles"]
    density_buf  -> update_cs   [label="write\ndensity"]
    update_cs  -> comp_tile     [label="terrain damage"]
    update_cs  -> density_buf   [label="particle density"]
    comp_tile  -> decompose     [label="read"]
    decompose  -> terrain_tiles [label="write back"]

    // ─── Render data flow ───
    comp_tile    -> terrain_rp  [label="terrain\nbuffer"]
    terrain_rp   -> game_tex    [label="render"]
    density_buf  -> particle_rp [label="density\nbuffer"]
    particle_rp  -> game_tex    [label="render"]
    ship         -> ship_rp     [label="position\n& angle"]
    ship_rp      -> game_tex    [label="render"]
    game_tex     -> blit_rp     [label="sample"]
    viewport     -> blit_rp     [label="camera\nuniforms"]
    blit_rp      -> swapchain   [label="present"]

    // ─── Ordering hints (same rank) ───
    { rank=same; compose; emit_cs; clear_cs }
    { rank=same; terrain_rp; particle_rp; ship_rp }
}
